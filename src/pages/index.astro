---
// Kinetics — spring-physics motion gallery.
// The body markup lives in src/content/body.html and is imported raw so the
// embedded React code samples (full of {}, backticks and ${}) are never parsed
// as Astro/JSX expressions.
import body from '../content/body.html?raw';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kinetics — Spring-physics motion for web interfaces</title>
  <meta
    name="description"
    content="A library of spring-driven micro-interactions for web apps. Copy the CSS or React, tune the physics, ship the motion."
  />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#0E0E10" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Kinetics" />
  <meta property="og:title" content="Kinetics — Spring-physics motion for web interfaces" />
  <meta
    property="og:description"
    content="A library of spring-driven micro-interactions for web apps. Copy the CSS or React, tune the physics, ship the motion."
  />
  <meta property="og:url" content="https://kinetics.dev/" />
  <meta property="og:image" content="https://kinetics.dev/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Kinetics — Motion that has weight." />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Kinetics — Spring-physics motion for web interfaces" />
  <meta
    name="twitter:description"
    content="A library of spring-driven micro-interactions for web apps. Copy the CSS or React, tune the physics, ship the motion."
  />
  <meta name="twitter:image" content="https://kinetics.dev/og-image.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;800;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/hero.css" />
  <link rel="stylesheet" href="/css/gallery.css" />
  <link rel="stylesheet" href="/css/effects-a.css" />
  <link rel="stylesheet" href="/css/effects-b.css" />
  <link rel="stylesheet" href="/css/effects-c.css" />
  <link rel="stylesheet" href="/css/closing.css" />
</head>
<body>
  <Fragment set:html={body} />

  <script is:inline src="/js/main.js"></script>
  <script is:inline src="/js/physics-demo.js"></script>
</body>
</html>
